00000000 <_start>:

_start:
    /* 1. CONFIGURAR LA PILA (STACK POINTER) - CRÍTICO */
    /* Netboot carga el programa en 0x40000000. */
    /* Ponemos la pila 32KB (0x8000) más adelante para tener espacio de sobra. */
    li sp, 0x40008000
